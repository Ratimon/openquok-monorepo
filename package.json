{
  "name": "openquok-monorepo",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "---------------------- DEV WORKFLOW ----------------------": "",
    "web:dev": "pnpm --filter ./web dev",
    "web:build": "pnpm --filter ./web build",
    "web:dev:clean": "pnpm --filter ./web dev:clean",
    "backend:dev": "pnpm --filter ./backend dev",
    "backend:lint": "pnpm --filter ./backend lint",
    "backend:test:unit": "pnpm --filter ./backend test:unit",
    "backend:test:integration": "pnpm --filter ./backend test:integration",
    "backend:test:e2e": "pnpm --filter ./backend test:e2e",
    "backend:db:typegen": "pnpm --filter ./backend db:local:typegen",
    "backend:db:aggregate-migrations-all": "pnpm --filter ./backend db:aggregate-migrations-all",
    "backend:db:aggregate-migrations-single": "pnpm --filter ./backend db:aggregate-migrations-single",
    "backend:generate-routes-manifest": "node scripts/generate-routes-manifest.mjs",
    "backend:build": "pnpm --filter backend build",
    "backend:build:vercel": "pnpm common:build && pnpm --filter backend build:vercel",
    "common:build": "pnpm --filter openquok-common build",
    "orchestrator:build": "pnpm --filter openquok-orchestrator build",
    "orchestrator:build:deps": "pnpm common:build && pnpm backend:build && pnpm orchestrator:build",
    "orchestrator:dev:worker:integration-refresh-bullmq": "pnpm --filter openquok-orchestrator dev:worker:integration-refresh-bullmq",
    "orchestrator:dev:worker:notification-email-bullmq": "pnpm --filter openquok-orchestrator dev:worker:notification-email-bullmq",
    "orchestrator:dev:worker:scheduled-social-post-bullmq": "pnpm --filter openquok-orchestrator dev:worker:scheduled-social-post-bullmq",
    "orchestrator:worker:integration-refresh-bullmq": "pnpm orchestrator:dev:worker:integration-refresh-bullmq",
    "orchestrator:worker:notification-email-bullmq": "pnpm orchestrator:dev:worker:notification-email-bullmq",
    "orchestrator:worker:scheduled-social-post-bullmq": "pnpm orchestrator:dev:worker:scheduled-social-post-bullmq",
    "orchestrator:start:worker:integration-refresh-bullmq": "pnpm --filter openquok-orchestrator start:worker:integration-refresh-bullmq",
    "orchestrator:start:worker:notification-email-bullmq": "pnpm --filter openquok-orchestrator start:worker:notification-email-bullmq",
    "orchestrator:start:worker:scheduled-social-post-bullmq": "pnpm --filter openquok-orchestrator start:worker:scheduled-social-post-bullmq",
    "orchestrator:test:unit": "pnpm --filter openquok-orchestrator test:unit",
    "---------------------- VERCEL (backend or web) ----------------------": "",
    "vercel:env:sync:backend:prod": "node scripts/vercelSyncBackendEnv.mjs --cwd backend --env-file backend/.env.production.local --environment production",
    "vercel:deploy:backend": "pnpm backend:build:vercel && node scripts/vercelDeployBackend.mjs",
    "vercel:deploy:backend:prod": "pnpm backend:build:vercel && node scripts/vercelDeployBackend.mjs --prod",
    "vercel:env:sync:web:prod": "node scripts/vercelSyncWebEnv.mjs --cwd web --env-file web/.env.production.local --environment production",
    "vercel:deploy:web": "node scripts/vercelDeployWeb.mjs",
    "vercel:deploy:web:prod": "node scripts/vercelDeployWeb.mjs --prod",
    "---------------------- RAILWAY (orchestrator workers) ----------------------": "",
    "railway:orchestrator:build": "pnpm orchestrator:build:deps",
    "railway:orchestrator:start:integration-refresh": "pnpm orchestrator:start:worker:integration-refresh-bullmq",
    "railway:orchestrator:start:notification-email": "pnpm orchestrator:start:worker:notification-email-bullmq",
    "railway:orchestrator:start:scheduled-social-post": "pnpm orchestrator:start:worker:scheduled-social-post-bullmq",
    "railway:setup:integration-refresh": "node scripts/railwaySetupWorkerService.mjs --service-name openquok-worker-integration-refresh --railpack-config-file railpack.integration-refresh.json --env-file orchestrator/.env.production.local --var ORCHESTRATOR_INTEGRATION_REFRESH_TRANSPORT=bullmq",
    "railway:setup:notification-email": "node scripts/railwaySetupWorkerService.mjs --service-name openquok-worker-notification-email --railpack-config-file railpack.notification-email.json --env-file orchestrator/.env.production.local --var ORCHESTRATOR_NOTIFICATION_EMAIL_TRANSPORT=bullmq",
    "railway:setup:scheduled-social-post": "node scripts/railwaySetupWorkerService.mjs --service-name openquok-worker-scheduled-social-post --railpack-config-file railpack.scheduled-social-post.json --env-file orchestrator/.env.production.local --var ORCHESTRATOR_SCHEDULED_SOCIAL_POST_TRANSPORT=bullmq",
    "railway:deploy:integration-refresh": "cross-env RAILPACK_CONFIG_FILE=railpack.integration-refresh.json railway up",
    "railway:deploy:notification-email": "cross-env RAILPACK_CONFIG_FILE=railpack.notification-email.json railway up",
    "railway:deploy:scheduled-social-post": "cross-env RAILPACK_CONFIG_FILE=railpack.scheduled-social-post.json railway up"
  },
  "keywords": [],
  "author": "Rati Montreewat",
  "license": "AGPL-3.0-or-later",
  "devDependencies": {
    "@railway/cli": "^4.35.0",
    "cross-env": "^7.0.3",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@railway/cli",
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "glob": "^13.0.0",
      "mkdirp": "^1.0.4",
      "uuid": "^8.3.2",
      "node-domexception": "^2.0.2"
    },
    "allowedDeprecatedVersions": {
      "har-validator": "5.1.5",
      "phin": "3.7.1",
      "request": "2.88.2"
    }
  }
}
