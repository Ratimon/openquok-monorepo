# Minimal template for BullMQ workers (copy keys into your host / secret store).
# Dotenv is loaded from the backend package directory (see backend/config/loadBackendDotenv.cjs),
# not from orchestrator/. — use backend/.env.*.local for file-based local dev, or inject these only.

NODE_ENV=production

# Redis (match API)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_BULLMQ_DB=0

# BullMQ transport (use when running dedicated workers)
ORCHESTRATOR_INTEGRATION_REFRESH_TRANSPORT=bullmq
ORCHESTRATOR_NOTIFICATION_EMAIL_TRANSPORT=bullmq
ORCHESTRATOR_SCHEDULED_SOCIAL_POST_TRANSPORT=bullmq

# Supabase (server-side access)
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- integration-refresh worker: add provider secrets only for integrations you refresh ---
# THREADS_APP_ID=
# THREADS_APP_SECRET=

# --- notification-email worker ---
# EMAIL_ENABLED=true
# RESEND_SECRET_KEY=
# SITE_NAME=
# SENDER_EMAIL_ADDRESS=
