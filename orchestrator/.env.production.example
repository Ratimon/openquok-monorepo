# Minimal template for BullMQ workers (copy keys into your host / secret store).
# Note: worker runtime config is sourced from `backend/config/GlobalConfig.ts`.
# In production hosts (Railway, Fly, etc) you typically inject env vars directly.
#
# Local development: prefer a local Docker Redis (see repo-root `infra/docker-compose.yml`) and keep
# NODE_ENV=development so workers never accidentally connect to production Redis.

NODE_ENV=production

# Redis (match API)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_BULLMQ_DB=0
REDIS_TLS=false
REDIS_TLS_REJECT_UNAUTHORIZED=true
REDIS_PREFIX=app:cache:
REDIS_MAX_RECONNECT_ATTEMPTS=10
REDIS_ENABLE_OFFLINE_QUEUE=true
REDIS_USE_SCAN=true

# Cache: set to redis in production when using Redis (match API). Default is memory; if REDIS_HOST is set the app still forces Redis but logs a warning until CACHE_PROVIDER=redis.
CACHE_PROVIDER=redis

# BullMQ worker tuning (optional)
BULLMQ_WORKER_LOCK_DURATION_MS=

# Worker health HTTP: GET /health and GET /health/status (Redis PING + queue depth for uptime monitors).
# Port resolution (first match wins): ORCHESTRATOR_WORKER_HEALTH_PORT=0 disables the listener;
# else host PORT (Railway injects this per worker service — preferred in production);
# else ORCHESTRATOR_WORKER_HEALTH_PORT if set to a positive number; else 3091.
# Production on Railway: leave empty — do not set 3091. Point health checks at /health/status using Railway PORT.
# Other hosts without PORT: set e.g. 3091 to match your load balancer. Local dev without a free port: use 0.
ORCHESTRATOR_WORKER_HEALTH_PORT=

# BullMQ transport (use when running dedicated workers)
ORCHESTRATOR_INTEGRATION_REFRESH_TRANSPORT=bullmq
ORCHESTRATOR_NOTIFICATION_EMAIL_TRANSPORT=bullmq
ORCHESTRATOR_SCHEDULED_SOCIAL_POST_TRANSPORT=bullmq

# Supabase (server-side access; new key format — see
# https://github.com/orgs/supabase/discussions/29260)
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Storage (required for publishing media posts; Meta must fetch a public HTTPS URL)
STORAGE_PROVIDER=r2
STORAGE_R2_PUBLIC_BASE_URL=https://media.openquok.com

# Optional (only required if the worker needs to mint public URLs from private objects, or upload)
STORAGE_R2_ACCOUNT_ID=
STORAGE_R2_ACCESS_KEY_ID=
STORAGE_R2_SECRET_ACCESS_KEY=
STORAGE_R2_BUCKET=
STORAGE_R2_REGION=APAC

# --- Provider OAuth (set only for channels you use) ---
# integration-refresh worker: required for cron token refresh per provider
# scheduled-social-post worker: required when publish retries refresh tokens
# Facebook Page + Instagram (Business) share FACEBOOK_APP_*; Instagram Standalone uses INSTAGRAM_APP_*.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
THREADS_APP_ID=
THREADS_APP_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# X (Twitter) — OAuth 1.0a; redirect {FRONTEND_DOMAIN_URL}/integration/oauth/x
X_API_KEY=
X_API_SECRET=
DISABLE_X_ANALYTICS=false

# --- notification-email worker ---
# Leave false when this worker should not send mail (typical self-host / production without a provider).
EMAIL_ENABLED=false
EMAIL_FROM_NAME=
EMAIL_FROM_ADDRESS=
RESEND_SECRET_KEY=
SITE_NAME=
SENDER_EMAIL_ADDRESS=

# AWS (dev/test email, optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Sentry (optional)
SENTRY_ENABLED=true
SENTRY_DSN=
