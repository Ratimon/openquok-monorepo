# syntax=docker/dockerfile:1
# Build from monorepo root: docker build -f web/Dockerfile .
# Pass VITE_* build args (see ARG list below) for client bundle configuration.

ARG NODE_VERSION=24-bookworm-slim

FROM node:${NODE_VERSION} AS base
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable && corepack prepare pnpm@10.30.3 --activate
WORKDIR /app

FROM base AS deps
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY common/package.json common/
COPY web/package.json web/
COPY web/.npmrc web/
RUN pnpm install --frozen-lockfile --ignore-scripts --filter web --filter openquok-common \
	&& pnpm rebuild esbuild sharp

FROM deps AS build
COPY common common
COPY web web
COPY agent/skills/openquok-core/resources/examples agent/skills/openquok-core/resources/examples

# SvelteKit inlines VITE_* at build time — set via compose build.args or --build-arg.
ARG VITE_API_BASE_URL=http://localhost:3000
ARG VITE_FRONTEND_DOMAIN_URL=http://localhost:4007
ARG VITE_PUBLIC_SUPABASE_URL=
ARG VITE_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
ARG VITE_PUBLIC_STRIPE_PUBLISHABLE_KEY=
ARG VITE_PUBLIC_STRIPE_PRICE_ID_SOLO_MONTHLY=
ARG VITE_PUBLIC_STRIPE_PRICE_ID_SOLO_YEARLY=
ARG VITE_PUBLIC_STRIPE_PRICE_ID_TEAM_MONTHLY=
ARG VITE_PUBLIC_STRIPE_PRICE_ID_TEAM_YEARLY=
ARG VITE_PUBLIC_STRIPE_PRICE_ID_ULTIMATE_MONTHLY=
ARG VITE_PUBLIC_STRIPE_PRICE_ID_ULTIMATE_YEARLY=
ARG VITE_PUBLIC_STRIPE_PRICE_ID_MAX_MONTHLY=
ARG VITE_PUBLIC_STRIPE_PRICE_ID_MAX_YEARLY=
ARG VITE_MEDIA_LIBRARY_UPLOAD=local
ARG VITE_STORAGE_R2_PUBLIC_BASE_URL=
ARG VITE_SUPPORT_EMAIL_ADDRESS=
ARG VITE_PUBLIC_GOOGLE_ANALYTICS_MEASUREMENT_ID=
ARG VITE_PUBLIC_POSTHOG_KEY=
ARG VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
ARG VITE_PUBLIC_FACEBOOK_PIXEL=

ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_FRONTEND_DOMAIN_URL=$VITE_FRONTEND_DOMAIN_URL
ENV VITE_PUBLIC_SUPABASE_URL=$VITE_PUBLIC_SUPABASE_URL
ENV VITE_PUBLIC_SUPABASE_PUBLISHABLE_KEY=$VITE_PUBLIC_SUPABASE_PUBLISHABLE_KEY
ENV VITE_PUBLIC_STRIPE_PUBLISHABLE_KEY=$VITE_PUBLIC_STRIPE_PUBLISHABLE_KEY
ENV VITE_PUBLIC_STRIPE_PRICE_ID_SOLO_MONTHLY=$VITE_PUBLIC_STRIPE_PRICE_ID_SOLO_MONTHLY
ENV VITE_PUBLIC_STRIPE_PRICE_ID_SOLO_YEARLY=$VITE_PUBLIC_STRIPE_PRICE_ID_SOLO_YEARLY
ENV VITE_PUBLIC_STRIPE_PRICE_ID_TEAM_MONTHLY=$VITE_PUBLIC_STRIPE_PRICE_ID_TEAM_MONTHLY
ENV VITE_PUBLIC_STRIPE_PRICE_ID_TEAM_YEARLY=$VITE_PUBLIC_STRIPE_PRICE_ID_TEAM_YEARLY
ENV VITE_PUBLIC_STRIPE_PRICE_ID_ULTIMATE_MONTHLY=$VITE_PUBLIC_STRIPE_PRICE_ID_ULTIMATE_MONTHLY
ENV VITE_PUBLIC_STRIPE_PRICE_ID_ULTIMATE_YEARLY=$VITE_PUBLIC_STRIPE_PRICE_ID_ULTIMATE_YEARLY
ENV VITE_PUBLIC_STRIPE_PRICE_ID_MAX_MONTHLY=$VITE_PUBLIC_STRIPE_PRICE_ID_MAX_MONTHLY
ENV VITE_PUBLIC_STRIPE_PRICE_ID_MAX_YEARLY=$VITE_PUBLIC_STRIPE_PRICE_ID_MAX_YEARLY
ENV VITE_MEDIA_LIBRARY_UPLOAD=$VITE_MEDIA_LIBRARY_UPLOAD
ENV VITE_STORAGE_R2_PUBLIC_BASE_URL=$VITE_STORAGE_R2_PUBLIC_BASE_URL
ENV VITE_SUPPORT_EMAIL_ADDRESS=$VITE_SUPPORT_EMAIL_ADDRESS
ENV VITE_PUBLIC_GOOGLE_ANALYTICS_MEASUREMENT_ID=$VITE_PUBLIC_GOOGLE_ANALYTICS_MEASUREMENT_ID
ENV VITE_PUBLIC_POSTHOG_KEY=$VITE_PUBLIC_POSTHOG_KEY
ENV VITE_PUBLIC_POSTHOG_HOST=$VITE_PUBLIC_POSTHOG_HOST
ENV VITE_PUBLIC_FACEBOOK_PIXEL=$VITE_PUBLIC_FACEBOOK_PIXEL

ENV NODE_ENV=production
ENV NODE_OPTIONS=--max-old-space-size=8192
ENV OPENQUOK_ADAPTER=node
ENV DOCKER=1
RUN pnpm --filter web exec svelte-kit sync \
	&& pnpm --filter openquok-common build \
	&& pnpm --filter web build

FROM base AS runtime
ENV NODE_ENV=production
ENV HOST=0.0.0.0
ENV PORT=3000
WORKDIR /app
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY common/package.json common/
COPY web/package.json web/
COPY web/.npmrc web/
COPY --from=build /app/common/dist common/dist
COPY --from=build /app/web/build web/build
RUN pnpm install --frozen-lockfile --prod --ignore-scripts --filter web --filter openquok-common \
	&& chown -R node:node /app
USER node
WORKDIR /app/web
EXPOSE 3000
HEALTHCHECK --interval=30s --timeout=5s --start-period=90s --retries=3 \
	CMD node -e "fetch('http://127.0.0.1:3000/').then((r)=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"
CMD ["node", "build"]
