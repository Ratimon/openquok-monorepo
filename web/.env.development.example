# Support email (used as default "From" for admin replies, and as fallback on legal pages)
VITE_SUPPORT_EMAIL_ADDRESS=support@openquok.com

# API: leave unset in dev to use same-origin `/api` (hooks.server.ts + vite proxy forward to the backend).
# Pointing at http://localhost:3000 breaks Google sign-in when the app runs on https://localhost:5173.
# VITE_API_BASE_URL=

# Optional: if the API listens somewhere other than localhost:3000
# DEV_BACKEND_PROXY_TARGET=http://localhost:3000

# FRONTEND (web) variables
VITE_FRONTEND_DOMAIN_URL=https://localhost:5173

# Public origin for R2-hosted composer images (no trailing slash). See docs/configuration-backend/cloudflare-r2.
VITE_STORAGE_R2_PUBLIC_BASE_URL=

# Storage provider for the account media uploader:
# - cloudflare: direct multipart upload to R2 (requires bucket CORS). Default if unset or not `local`.
# - local: upload via API and preview from /uploads (proxied to backend in dev)
# VITE_STORAGE_PROVIDER=cloudflare
VITE_STORAGE_PROVIDER=local

#  Supabase variable
VITE_PUBLIC_SUPABASE_URL=

# Google tag id
VITE_PUBLIC_GOOGLE_ANALYTICS_MEASUREMENT_ID=G-1234567