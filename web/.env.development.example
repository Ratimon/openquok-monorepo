# Support email (used as default "From" for admin replies, and as fallback on legal pages)
VITE_SUPPORT_EMAIL_ADDRESS=support@openquok.com

# API: leave unset in dev to use same-origin `/api` (hooks.server.ts + vite proxy forward to the backend).
# Pointing at http://localhost:3000 breaks Google sign-in when the app runs on https://localhost:5173.
# VITE_API_BASE_URL=

# Optional: if the API listens somewhere other than localhost:3000
# DEV_BACKEND_PROXY_TARGET=http://localhost:3000

# FRONTEND (web) variables
VITE_FRONTEND_DOMAIN_URL=https://localhost:5173

# CLI device-flow auth server (`agent/server`). Used by `/cli/device/*` routes when testing auth:login locally.
CLI_AUTH_SERVER_URL=http://localhost:3111

# Public origin for R2-hosted composer images (no trailing slash). See docs/configuration-backend/cloudflare-r2.
VITE_STORAGE_R2_PUBLIC_BASE_URL=

# Account media library — how the browser sends files (see docs/configuration-backend/cloudflare-r2).
# Omit or `direct` = presigned multipart to R2 (default). Use `local` with STORAGE_PROVIDER=local for disk dev.
# VITE_MEDIA_LIBRARY_UPLOAD=direct
VITE_MEDIA_LIBRARY_UPLOAD=local

# Supabase (must match backend/.env.development.local PUBLIC_SUPABASE_URL for local dev)
# e.g. http://127.0.0.1:54321 after `supabase start` — not a hosted project unless backend uses it too.
VITE_PUBLIC_SUPABASE_URL=

# Google tag id
VITE_PUBLIC_GOOGLE_ANALYTICS_MEASUREMENT_ID=G-1234567

# PostHog (product analytics — skipped when VITE_PUBLIC_STRIPE_PUBLISHABLE_KEY is empty)
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Meta Pixel (browser + server CAPI via backend FACEBOOK_PIXEL_*)
VITE_PUBLIC_FACEBOOK_PIXEL=

# Stripe (workspace subscriptions — see docs/configuration-backend/stripe)
VITE_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
# Pre-created Stripe Price ids (price_…) — one per tier and cadence (Products → recurring prices)
VITE_PUBLIC_STRIPE_PRICE_ID_SOLO_MONTHLY=
VITE_PUBLIC_STRIPE_PRICE_ID_SOLO_YEARLY=
VITE_PUBLIC_STRIPE_PRICE_ID_TEAM_MONTHLY=
VITE_PUBLIC_STRIPE_PRICE_ID_TEAM_YEARLY=
VITE_PUBLIC_STRIPE_PRICE_ID_ULTIMATE_MONTHLY=
VITE_PUBLIC_STRIPE_PRICE_ID_ULTIMATE_YEARLY=
VITE_PUBLIC_STRIPE_PRICE_ID_MAX_MONTHLY=
VITE_PUBLIC_STRIPE_PRICE_ID_MAX_YEARLY=