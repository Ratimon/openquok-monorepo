# Copy to web/.env.production.local (gitignored), then: pnpm vercel:env:sync:web:prod

# Support email (used as default "From" for admin replies, and as fallback on legal pages)
VITE_SUPPORT_EMAIL_ADDRESS=support@openquok.com

# Backend API origin (no trailing slash)
VITE_API_BASE_URL=https://api.openquok.com

# Public web origin (no trailing slash)
VITE_FRONTEND_DOMAIN_URL=https://www.openquok.com

# CLI device-flow API (agent/server). Server-only — used by /cli/device/* routes (not exposed to the browser).
CLI_AUTH_SERVER_URL=https://cli-auth.openquok.com

# Public origin for R2-hosted composer images (no trailing slash). See docs/configuration-backend/cloudflare-r2.
VITE_STORAGE_R2_PUBLIC_BASE_URL=https://media.openquok.com

# Account media library — how the browser sends files (see docs/configuration-backend/cloudflare-r2).
# `direct` = presigned multipart to R2 (typical production). Use `local` only with STORAGE_PROVIDER=local.
VITE_MEDIA_LIBRARY_UPLOAD=direct

# Supabase (public URL only)
VITE_PUBLIC_SUPABASE_URL=

# Google Analytics
VITE_PUBLIC_GOOGLE_ANALYTICS_MEASUREMENT_ID=

# Stripe (publishable key + price IDs)
VITE_PUBLIC_STRIPE_PUBLISHABLE_KEY=
VITE_PUBLIC_STRIPE_PRICE_ID_LITE_PLAN=
VITE_PUBLIC_STRIPE_PRICE_ID_BASIC_PLAN=
VITE_PUBLIC_STRIPE_PRICE_ID_STARTER_PACK=
VITE_PUBLIC_STRIPE_PRICE_ID_GROWTH_PACK=
VITE_PUBLIC_STRIPE_PRICE_ID_PROFESSIONAL_PACK=
VITE_PUBLIC_STRIPE_PRICE_ID_PAGE_1_YEAR_PACK=
VITE_PUBLIC_STRIPE_PRICE_ID_PAGE_LIFETIME_PACK=
