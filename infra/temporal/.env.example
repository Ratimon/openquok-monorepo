# Optional overrides for infra/temporal/docker-compose.yaml
# Copy to infra/temporal/.env or set in your shell before `docker compose up`.

# Host IP for published gRPC + Web UI ports (default 127.0.0.1 = not LAN-wide).
# Use 0.0.0.0 only if another machine must reach Temporal on your host or your hoster requires it.
# TEMPORAL_BIND_HOST=127.0.0.1

# gRPC frontend (default 7233). Backend env: TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_GRPC_PORT=7233

# Temporal Web UI (default 8080)
TEMPORAL_UI_PORT=8080

# Comma-separated origins allowed by Temporal UI (browser)
# TEMPORAL_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
