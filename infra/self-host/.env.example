# -----------------------------------------------------------------------------
# OpenQuok self-host env (Docker Compose)
# Copy to infra/self-host/.env and fill required values before:
#   docker compose -f infra/self-host/docker-compose.yml up --build
#
# Audience: operator machine / private network — not a hardened public SaaS edge.
# API + workers load this file; the web service does not (VITE_* are build args).
# Never commit .env. Prefer localhost or a firewall before publishing ports.
#
# Changing VITE_* requires rebuilding the web image (client bundle is baked at build time).
# Other vars: recreate containers after edit (compose up -d --force-recreate).
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Public URLs (change for real domains / reverse proxy)
# -----------------------------------------------------------------------------
FRONTEND_DOMAIN_URL=http://localhost:4007
BACKEND_DOMAIN_URL=http://localhost:3000
VITE_FRONTEND_DOMAIN_URL=http://localhost:4007
# Docker self-host: leave empty so the web container uses same-origin /api (proxied to the api service).
# Do not set to http://localhost:3000 — SSR inside the web container would call itself, not the API.
VITE_API_BASE_URL=
# Optional override for `docker compose` web image build only (defaults to empty).
# OPENQUOK_WEB_API_BASE_URL=

# Optional host port overrides (compose publish maps)
# OPENQUOK_WEB_HOST_PORT=4007
# OPENQUOK_API_HOST_PORT=3000
# OPENQUOK_WORKER_HEALTH_HOST_PORT=3091
# OPENQUOK_AGENT_HOST_PORT=3111

# -----------------------------------------------------------------------------
# Self-host friendly defaults
# -----------------------------------------------------------------------------
SITE_NAME=Openquok
SENDER_EMAIL_ADDRESS=noreply@example.com
NODE_ENV=production
PORT=3000
API_PREFIX=/api/v1

# No outbound mail; signup auto-verifies. Set true + Resend/SES when you want email.
EMAIL_ENABLED=false
IS_EMAIL_SERVER_OFFLINE=false

# Empty publishable key disables billing / First Billing paywall.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_PUBLIC_STRIPE_PUBLISHABLE_KEY=

DISABLE_REGISTRATION=false
# true for plain HTTP on localhost; set false behind HTTPS reverse proxy.
NOT_SECURED=true

# Rate limiting is disabled by default when NOT_SECURED=true (avoids SSR from the web
# container sharing one Docker IP and hitting production limits). Set to test limits:
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_MAX=1000

# Shared secret for invite links + OAuth token hashing. Generate: openssl rand -hex 32
SECURITY_SECRET=

# -----------------------------------------------------------------------------
# Supabase (required — hosted project or `supabase start` on the host)
# Apply OpenQuok migrations to this project before first use.
# -----------------------------------------------------------------------------
# Local `supabase start` on the host (from `supabase status` API URL, usually port 54321):
#   API + workers (in Docker): host.docker.internal — NOT 127.0.0.1
#   Web build (browser on your machine): 127.0.0.1 is fine for VITE_PUBLIC_SUPABASE_URL
PUBLIC_SUPABASE_URL=http://host.docker.internal:54321
PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
VITE_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
VITE_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# Redis (compose service DNS — do not point at a shared production instance)
# -----------------------------------------------------------------------------
CACHE_PROVIDER=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_BULLMQ_DB=0
REDIS_TLS=false
REDIS_TLS_REJECT_UNAUTHORIZED=true
REDIS_PREFIX=app:cache:

ORCHESTRATOR_INTEGRATION_REFRESH_TRANSPORT=bullmq
ORCHESTRATOR_NOTIFICATION_EMAIL_TRANSPORT=bullmq
ORCHESTRATOR_SCHEDULED_SOCIAL_POST_TRANSPORT=bullmq

# -----------------------------------------------------------------------------
# Storage (local disk volume mounted at /uploads on api + workers)
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=local
UPLOAD_DIRECTORY=/uploads
VITE_MEDIA_LIBRARY_UPLOAD=local
VITE_STORAGE_R2_PUBLIC_BASE_URL=

# -----------------------------------------------------------------------------
# Optional / usually empty for self-host
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENABLED=false
BULL_BOARD_ENABLED=false
RESEND_SECRET_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
VITE_SUPPORT_EMAIL_ADDRESS=
VITE_PUBLIC_GOOGLE_ANALYTICS_MEASUREMENT_ID=
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
VITE_PUBLIC_FACEBOOK_PIXEL=

# -----------------------------------------------------------------------------
# Social provider apps (optional until you connect channels)
# -----------------------------------------------------------------------------
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
THREADS_APP_ID=
THREADS_APP_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
X_API_KEY=
X_API_SECRET=

# -----------------------------------------------------------------------------
# Optional CLI profile (`--profile cli`): device-flow auth helper
# Register an OAuth app (Settings → Developers → Apps); redirect:
#   http://localhost:3111/device/callback
# -----------------------------------------------------------------------------
CLI_AUTH_SERVER_URL=http://localhost:3111
CLI_DATABASE_URL=postgresql://openquok:openquok@postgres:5432/openquok_cli_auth
SERVER_URL=http://localhost:3111
OPENQUOK_FRONTEND_URL=http://localhost:4007
OPENQUOK_API_URL=http://localhost:3000
OPENQUOK_OAUTH_CLIENT_ID=
OPENQUOK_OAUTH_CLIENT_SECRET=
OPENQUOK_AUTHORIZE_PATH=/oauth/authorize
