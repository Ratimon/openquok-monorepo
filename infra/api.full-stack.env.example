# -----------------------------------------------------------------------------
# API env for infra/docker-compose.full-stack.example.yaml — copy to infra/api.full-stack.env and edit.
#
# From repo root, use one of:
#   cp infra/api.full-stack.env.example infra/api.full-stack.env
#   cp backend/.env.production.local infra/api.full-stack.env
#   cp backend/.env.development.example infra/api.full-stack.env
#
# infra/api.full-stack.env is gitignored (see .gitignore). Same variable names as
# backend/.env.* / backend/config/GlobalConfig.ts — but values here must match the
# Compose network (Redis + Temporal service names), not localhost.
#
# Railway canvas: copy infra/docker-compose.railway.example.yaml → infra/docker-compose.railway.yaml
# (gitignored). From repo root, pnpm railway:sync-env merges backend/.env.production.local into that
# YAML by default (override with --from infra/api.full-stack.env if you keep a Compose-only copy).
# Or set variables in the Railway dashboard after import.
#
# Optional Compose-time substitution (published host port for the API):
#   export API_PORT=3000
# or use: docker compose --env-file path/to/compose.env -f infra/docker-compose.full-stack.example.yaml ...
# -----------------------------------------------------------------------------

# --- Core server ---
NODE_ENV=production
PORT=3000
SITE_NAME=Openquok
SENDER_EMAIL_ADDRESS=
FRONTEND_DOMAIN_URL=https://your-frontend.example
BACKEND_DOMAIN_URL=https://your-api.example
API_PREFIX=/api/v1
ALLOWED_FRONTEND_ORIGINS=

# --- Auth ---
DISABLE_REGISTRATION=false
NOT_SECURED=false
INVITE_TOKEN_SECRET=
JWT_SECRET=

# --- Supabase (required) ---
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Email ---
EMAIL_ENABLED=false
IS_EMAIL_SERVER_OFFLINE=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
RESEND_SECRET_KEY=

# --- Sentry ---
SENTRY_DSN=
SENTRY_ENABLED=true

# --- Cache / Redis (Compose service name `redis`, not localhost) ---
CACHE_PROVIDER=redis
CACHE_DEFAULT_TTL=300
CACHE_LOG_HITS=true
CACHE_LOG_MISSES=true
CACHE_CHECK_PERIOD=60
CACHE_USE_CLONES=false
CACHE_ENABLED=true
CACHE_ENABLE_PATTERNS=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=app:cache:
REDIS_MAX_RECONNECT_ATTEMPTS=10
REDIS_ENABLE_OFFLINE_QUEUE=true
REDIS_USE_SCAN=true

# --- Rate limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX=30
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=50
OAUTH_RATE_LIMIT_WINDOW_MS=300000
OAUTH_RATE_LIMIT_MAX=20

# --- Temporal (Compose service name `temporal`, not localhost) ---
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default

# --- Integrations (optional) ---
THREADS_APP_ID=
THREADS_APP_SECRET=
