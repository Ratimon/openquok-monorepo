    "openquok",
    "ai",
    "ai-agent",
    "agent-teams",
    "agent-harness",
    "cli",
    "claude-cowork",
    "claude-code",
    "social-media",
    "scheduling",
    "automation",
    "ai-agent",
    "command-line",
    "twitter",
    "x",
    "threads",
    "linkedin",
    "facebook",
    "instagram",
    "tiktok",
    "youtube",
    "reddit"
  ],
  "author": {
    "name": "Rati Montreewat",
    "url": "https://github.com/Ratimon"
  },
  "license": "AGPL-3.0",
  "repository": "github:Ratimon/openquok-monorepo/agent",
  "packageManager": "pnpm@10.30.3"
}
