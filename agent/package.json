{
  "name": "@openquok/auto-cli",
  "version": "0.0.9",
  "description": "Programmatic CLI for the Openquok scheduling API — designed for automation and AI agents. It is to automate social media posting, manage scheduled content, and upload media via the Openquok API across the social platforms you’ve connected to Openquok",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "openquok": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "cli": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts -- --help",
    "start": "node dist/index.js",
    "test": "node ./run-vitest.mjs",
    "test:unit": "node ./run-vitest.mjs run src",
    "test:e2e": "node ./run-vitest.mjs run tests/e2e",
    "test:watch": "node ./run-vitest.mjs --watch",
    "publish:manual": "pnpm run build && pnpm publish --access public",
    "publish:clawhub:dry-run": "clawhub skill publish ./skills/openquok-core --slug openquok-core --name \"OpenQuok Core\" --dry-run",
    "publish:clawhub:manual": "clawhub skill publish ./skills/openquok-core --slug openquok-core --name \"OpenQuok Core\"",
    "prepublishOnly": "pnpm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "skills",
    "skills/LICENSE"
  ],
  "keywords": [
    "openquok",
    "ai",
    "ai-agent",
    "agent-teams",
    "agent-harness",
    "cli",
    "claude-cowork",
    "claude-code",
    "social-media",
    "scheduling",
    "automation",
    "ai-agent",
    "command-line",
    "twitter",
    "x",
    "threads",
    "linkedin",
    "facebook",
    "instagram",
    "tiktok",
    "youtube",
    "reddit"
  ],
  "author": {
    "name": "Rati Montreewat",
    "url": "https://github.com/Ratimon"
  },
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=20.19.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ratimon/openquok-monorepo.git",
    "directory": "agent"
  },
  "packageManager": "pnpm@10.30.3",
  "dependencies": {
    "form-data": "^4.0.4",
    "node-fetch": "^3.3.2",
    "open": "^10.2.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@types/node": "^25.6.0",
    "@types/yargs": "^17.0.33",
    "tsup": "^8.5.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
