{
  "name": "@openquok/auto-cli",
  "version": "0.0.1",
  "description": "Openquok CLI for the social media scheduling API.",
  "main": "dist/index.js",
  "bin": {
    "openquok": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts -- --help",
    "start": "node dist/index.js",
    "publish:manual": "pnpm run build && pnpm publish --access public",
    "prepublishOnly": "pnpm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "SKILL.md",
    "LICENSE"
  ],
  "type": "module",
  "keywords": [
    "openquok",
    "ai",
    "ai-agent",
    "agent-teams",
    "agent-harness",
    "cli",
    "claude-cowork",
    "claude-code",
    "social-media",
    "scheduling",
    "automation",
    "ai-agent",
    "command-line",
    "twitter",
    "x",
    "threads",
    "linkedin",
    "facebook",
    "instagram",
    "tiktok",
    "youtube",
    "reddit"
  ],
  "author": {
    "name": "Rati Montreewat",
    "url": "https://github.com/Ratimon"
  },
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "github:Ratimon/openquok-monorepo/agent"
  },
  "packageManager": "pnpm@10.30.3",
  "dependencies": {
    "form-data": "^4.0.4",
    "node-fetch": "^3.3.2",
    "open": "^10.2.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/yargs": "^17.0.33",
    "tsup": "^8.5.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
