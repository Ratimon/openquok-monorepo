# Local development defaults (safe placeholders).
# Never commit real secrets.

NODE_ENV=development

# Required
# For local Postgres via `docker compose -f infra/docker-compose.yml up -d postgres`:
DATABASE_URL=postgresql://openquok:openquok@localhost:5432/openquok_cli_auth

# Create an OAuth app in your local Openquok web dashboard (Settings → Developers → Apps),
# then paste the values here.
OPENQUOK_OAUTH_CLIENT_ID=
OPENQUOK_OAUTH_CLIENT_SECRET=

# Public origin of this server (no trailing slash).
# In local dev, the server typically runs on port 3111.
SERVER_URL=http://localhost:3111

# Optional overrides (defaults match hosted Openquok)
OPENQUOK_FRONTEND_URL=https://localhost:5173
OPENQUOK_AUTHORIZE_PATH=/oauth/authorize
OPENQUOK_API_URL=http://localhost:3000