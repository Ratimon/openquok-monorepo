# Copy to agent/server/.env.production.local (gitignored) for `pnpm vercel:env:sync:agent-server:prod`.
# Never commit real secrets.

NODE_ENV=production

# Required
DATABASE_URL=
OPENQUOK_OAUTH_CLIENT_ID=
OPENQUOK_OAUTH_CLIENT_SECRET=

# API origin (CLI polls /device/code and /device/token here). Stays on cli-auth.openquok.com.
SERVER_URL=https://cli-auth.openquok.com

# Browser steps (/cli/device/verify, /cli/device/callback) are served by the **web** app (www.openquok.com).
# The auth server only emits these URLs; deploy web with CLI_AUTH_SERVER_URL pointing back here.
BROWSER_ORIGIN=https://www.openquok.com

# Optional overrides (defaults match hosted Openquok)
# OPENQUOK_FRONTEND_URL=https://www.openquok.com
# OPENQUOK_API_URL=https://api.openquok.com
# OPENQUOK_AUTHORIZE_PATH=/oauth/authorize
