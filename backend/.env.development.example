# -----------------------------------------------------------------------------
# Backend – development env example
# Copy to backend/.env.development.local (or backend/.env) and set values.
# Load order: .env.development.local then .env (see config/GlobalConfig.ts).
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Basic
# -----------------------------------------------------------------------------
SITE_NAME=Openquok
SENDER_EMAIL_ADDRESS=support@example.com

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
FRONTEND_DOMAIN_URL=https://localhost:5173
# When the web app uses the Vite HTTPS dev server with `/api` proxied to this process, use the web origin so
# Supabase OAuth redirect_to matches the URL you allow in the dashboard (e.g. …/api/v1/auth/oauth/google/callback).
BACKEND_DOMAIN_URL=https://localhost:5173

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
API_PREFIX=/api/v1

# -----------------------------------------------------------------------------
# CORS (optional; comma-separated extra origins)
# -----------------------------------------------------------------------------
ALLOWED_FRONTEND_ORIGINS=

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
# Disable new user registration when true
DISABLE_REGISTRATION=false
# Dev only: relaxes auth cookie/header behavior over HTTP. Production: set NOT_SECURED=false or omit (default false).
NOT_SECURED=true
# Shared secret used for:
# - signing organization invite links
# - hashing OAuth client secrets / authorization codes / access tokens (raw secrets are never stored)
# Generate: `openssl rand -hex 32`
SECURITY_SECRET=


# -----------------------------------------------------------------------------
# OAuth
# -----------------------------------------------------------------------------
# Hosted Supabase: enable Google in the dashboard (Auth → Providers).
# Local supabase start (127.0.0.1:54321): set Client ID/secret in backend/supabase/.env and
# enabled = true under [auth.external.google] in backend/supabase/config.toml — see supabase/.env.example.
# This backend env file only needs BACKEND_DOMAIN_URL / FRONTEND_DOMAIN_URL for redirect URLs.



# -----------------------------------------------------------------------------
# Email (verification, welcome)
# -----------------------------------------------------------------------------
EMAIL_ENABLED=true
# When true, use local SES mock (e.g. aws-ses-v2-local) for email
IS_EMAIL_SERVER_OFFLINE=true

# -----------------------------------------------------------------------------
# Supabase (required for auth and DB)
# -----------------------------------------------------------------------------
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Cloudflare R2 (S3-compatible)
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=r2
STORAGE_R2_ACCOUNT_ID=
STORAGE_R2_ACCESS_KEY_ID=
STORAGE_R2_SECRET_ACCESS_KEY=
STORAGE_R2_BUCKET=
STORAGE_R2_REGION=auto
STORAGE_R2_PUBLIC_BASE_URL=

# -----------------------------------------------------------------------------
# Local uploads (only when STORAGE_PROVIDER=local)
# -----------------------------------------------------------------------------
# Absolute folder where the backend writes files. Backend serves them at /uploads/*.
# Public URLs are derived from FRONTEND_DOMAIN_URL + /uploads.
UPLOAD_DIRECTORY=

# -----------------------------------------------------------------------------
# AWS (SES for local/dev email)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# Resend (production email)
# -----------------------------------------------------------------------------
RESEND_SECRET_KEY=

# -----------------------------------------------------------------------------
# Sentry (error monitoring)
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENABLED=true

# -----------------------------------------------------------------------------
# Cache (memory or redis; used for module_configs etc.)
# -----------------------------------------------------------------------------
CACHE_PROVIDER=memory
CACHE_DEFAULT_TTL=300
CACHE_LOG_HITS=true
CACHE_LOG_MISSES=true
CACHE_CHECK_PERIOD=60
CACHE_USE_CLONES=false
CACHE_ENABLED=true
CACHE_ENABLE_PATTERNS=true

# Redis (when CACHE_PROVIDER=redis). Point at your local or managed Redis host.
# These placeholder lines target localhost:6379 with no password — they will FAIL integration checks
# (e.g. pnpm test:integration:bullmq-redis) unless you run Redis locally (e.g. Docker). Copy real host/port/password
# from your provider into .env.development.local; managed Redis often needs REDIS_TLS=true as well.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
REDIS_TLS_REJECT_UNAUTHORIZED=true
REDIS_PREFIX=app:cache:
REDIS_MAX_RECONNECT_ATTEMPTS=10
REDIS_ENABLE_OFFLINE_QUEUE=true
REDIS_USE_SCAN=true
# Optional: logical Redis DB for BullMQ / Flowcraft queues (defaults to REDIS_DB).
REDIS_BULLMQ_DB=0

# -----------------------------------------------------------------------------
# Orchestrator transport (optional; defaults in config/orchestratorFlows.ts)
# -----------------------------------------------------------------------------
# in_process = run Flowcraft in the API process (default). bullmq = API enqueues; run workers separately.
ORCHESTRATOR_INTEGRATION_REFRESH_TRANSPORT=bullmq
ORCHESTRATOR_NOTIFICATION_EMAIL_TRANSPORT=bullmq
ORCHESTRATOR_SCHEDULED_SOCIAL_POST_TRANSPORT=bullmq

# Flowcraft BullMQ workers: per-job lock TTL (ms). Default 600000 (10m). The stock @flowcraft/bullmq-adapter
# uses BullMQ’s 30s default without this, which can cause "could not renew lock" for long refresh/OAuth nodes.
# BULLMQ_WORKER_LOCK_DURATION_MS=600000

# -----------------------------------------------------------------------------
# Bull Board (BullMQ dashboard) — admin only
# -----------------------------------------------------------------------------
# Mounts under API_PREFIX at BULL_BOARD_PATH (default /admin-queues → /api/v1/admin-queues). Uses the same
# JWT + super admin RBAC as /api/v1/admin/*, but the URL is not /api/v1/admin/queues (that would be swallowed
# by the generic /admin mount before Bull Board; see routes/index.ts).
# IMPORTANT: This exposes job payloads and queue controls. Keep disabled unless you need it.
BULL_BOARD_ENABLED=true
BULL_BOARD_PATH=/admin-queues

# -----------------------------------------------------------------------------
# Rate limiting (global + auth; set RATE_LIMIT_ENABLED=false to disable)
# Global limit: requests per window per IP. In development the code default is
# 1000/hour; in production it's 30/hour. Override here if needed.
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX=60

# Auth routes (stricter, 15 min window)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=50

# OAuth routes (Google start + callback; 5 min window)
OAUTH_RATE_LIMIT_WINDOW_MS=300000
OAUTH_RATE_LIMIT_MAX=20


# Meta — Facebook Login (used for Instagram Business / Page-linked professional accounts).
# No trailing newline after values (breaks OAuth URLs as %0A in client_id / redirect_uri).
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""

# Meta — Instagram Login (standalone professional accounts)
INSTAGRAM_APP_ID=""
INSTAGRAM_APP_SECRET=""

# Redirect URI on the app must match: {FRONTEND_DOMAIN_URL}/integration/oauth/threads
# Social Media API Settings
THREADS_APP_ID=""
THREADS_APP_SECRET=""