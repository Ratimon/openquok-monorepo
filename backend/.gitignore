/node_modules
/dist

# Stray TypeScript / tsc emit next to source *.ts (build artifacts belong in dist/). Stops *.js / *.d.ts / maps from polluting the tree in the editor and git.
**/*.d.ts.map
**/*.js.map

**/*.d.ts
!types/openquok-orchestrator.d.ts
!types/aws-sdk-s3-request-presigner.d.ts

**/*.js
!jest.config.js
!eslint.config.js
!jest.integration.ratelimit.config.js
!tests/__mocks__/**

# Vercel outputDirectory (created by vercel-clean-after-build.sh; no index.html)
/public

# Dotenv files
.env*.local
!.env.development.example

# testing
coverage

# typegen temp (db:local:typegen / db:linked:typegen)
types/table-types.ts.tmp
.vercel
