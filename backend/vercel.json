{
	"version": 2,
	"framework": null,
	"env": {
		"OPENQUOK_SKIP_STANDALONE_LISTEN": "1"
	},
	"outputDirectory": "public",
	"installCommand": "cd .. && pnpm install --frozen-lockfile",
	"buildCommand": "pnpm run build:vercel",
	"rewrites": [
		{
			"source": "/(.*)",
			"destination": "/api"
		}
	]
}
