{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node", "jest"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "flowcraft": ["./node_modules/flowcraft/dist/index.d.mts"],
      "flowcraft/testing": ["./node_modules/flowcraft/dist/testing/index.d.mts"],
      "openquok-orchestrator": ["./types/openquok-orchestrator.d.ts"]
    }
  },
  "include": ["**/*.ts", "**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
